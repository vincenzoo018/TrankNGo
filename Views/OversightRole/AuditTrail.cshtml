@{
    ViewData["Title"] = "Audit Trail - Oversight";
    Layout = "~/Views/Shared/_LayoutApp.cshtml";
}

<div class="page-body">
    <div class="page-header">
        <div>
            <h1 class="page-header__title">Audit Trail</h1>
            <p class="page-header__subtitle">Oversight Officer - System activity log and compliance audit</p>
        </div>
    </div>

    <div class="card">
        <div class="card__header"><span class="card__title">System Activity Log</span></div>
        <div class="card__body" style="padding:0; overflow-x:auto;">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Timestamp</th>
                        <th>User</th>
                        <th>Action</th>
                        <th>Document #</th>
                        <th>Details</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Jun 29, 2026 4:35 PM</td>
                        <td>admin</td>
                        <td><span class="badge badge--in-progress badge--table">Document Endorsed</span></td>
                        <td><a href="#">TRK-2026-0145</a></td>
                        <td>Forwarded to HRMO</td>
                    </tr>
                    <tr>
                        <td>Jun 29, 2026 4:30 PM</td>
                        <td>mayor</td>
                        <td><span class="badge badge--completed badge--table">Document Approved</span></td>
                        <td><a href="#">TRK-2026-0144</a></td>
                        <td>Digital signature applied</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
