@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString()?.ToLower() ?? "";
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString()?.ToLower() ?? "";
    
    // Role resolution: check query param (for demo), then claims (for real auth)
    var queryRole = Context.Request.Query["role"].ToString();
    TrackNGo.Models.UserRole role;
    
    if (!string.IsNullOrEmpty(queryRole))
    {
        role = queryRole.ToLower() switch
        {
            "mayor" => TrackNGo.Models.UserRole.Mayor,
            "records" => TrackNGo.Models.UserRole.RecordsOfficer,
            "cart" => TrackNGo.Models.UserRole.OversightOfficer,
            "oversight" => TrackNGo.Models.UserRole.OversightOfficer,
            "admin" => TrackNGo.Models.UserRole.ExecutiveAdmin,
            _ => TrackNGo.Models.UserRole.ExecutiveAdmin
        };
    }
    else
    {
        // Try to get role from claims - stored as string name, not int
        var userRoleStr = Context.User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value;
        if (!string.IsNullOrEmpty(userRoleStr) && Enum.TryParse<TrackNGo.Models.UserRole>(userRoleStr, out var parsedRole))
        {
            role = parsedRole;
        }
        else
        {
            // Fallback to ExecutiveAdmin if no valid role found
            role = TrackNGo.Models.UserRole.ExecutiveAdmin;
        }
    }
    
    // Pass role to all links as query param so it persists during demo navigation
    var roleParam = !string.IsNullOrEmpty(queryRole) ? queryRole : role.ToString().ToLower();
}

<!-- SIDEBAR NAVIGATION -->
