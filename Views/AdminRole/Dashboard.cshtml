@model TrackNGo.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_LayoutApp.cshtml";
}

<div class="page-body">
    <div class="page-header">
        <div>
            <h1 class="page-header__title">Executive Admin Dashboard</h1>
            <p class="page-header__subtitle">Welcome back, @Model.UserFullName - System Administrator</p>
        </div>
    </div>

    <!-- Executive Admin Stat Cards -->
    <div class="stats-row">
        <div class="stat-card stat-card--primary">
            <div class="stat-card__number">@Model.NewlySubmittedCount</div>
            <div class="stat-card__label">Newly Submitted</div>
            <div class="stat-card__sub">Require endorsement</div>
        </div>
        <div class="stat-card">
            <div class="stat-card__number">@Model.InProgressCount</div>
            <div class="stat-card__label">In Progress</div>
            <div class="stat-card__sub">Under department review</div>
        </div>
        <div class="stat-card">
            <div class="stat-card__number">@Model.PendingMayorReviewCount</div>
            <div class="stat-card__label">Pending Mayor</div>
            <div class="stat-card__sub">Waiting for Mayor signature</div>
        </div>
        <div class="stat-card">
            <div class="stat-card__number">@Model.TotalDocuments</div>
            <div class="stat-card__label">Total Documents</div>
            <div class="stat-card__sub">All time</div>
        </div>
    </div>

    <!-- System Health -->
    <div class="stats-row" style="margin-top:20px;">
        <div class="stat-card">
            <div class="stat-card__number" style="color:var(--success)">@Model.ARTAComplianceRate%</div>
            <div class="stat-card__label">ARTA Compliance</div>
            <div class="stat-card__sub">Documents on time</div>
        </div>
        <div class="stat-card">
            <div class="stat-card__number" style="color:var(--warning)">@Model.WarningCount</div>
            <div class="stat-card__label">Warnings</div>
            <div class="stat-card__sub">Approaching deadline</div>
        </div>
        <div class="stat-card">
            <div class="stat-card__number" style="color:var(--danger)">@Model.ARTAFlaggedCount</div>
            <div class="stat-card__label">ARTA Flagged</div>
            <div class="stat-card__sub">Overdue documents</div>
        </div>
        <div class="stat-card">
            <div class="stat-card__number">@Model.CompletedCount</div>
            <div class="stat-card__label">Completed Today</div>
            <div class="stat-card__sub">Successfully processed</div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="card" style="margin-top:20px;">
        <div class="card__header">
            <span class="card__title">Quick Actions</span>
        </div>
        <div class="card__body">
            <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(200px, 1fr)); gap:16px;">
                <a href="/Document/Create?role=admin" class="quick-action-btn" style="text-decoration:none;">
                    <svg viewBox="0 0 24 24" style="width:24px;height:24px;stroke:currentColor;"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    <span>Submit New Document</span>
                </a>
                <a href="/Admin/Index?role=admin" class="quick-action-btn" style="text-decoration:none;">
                    <svg viewBox="0 0 24 24" style="width:24px;height:24px;stroke:currentColor;"><circle cx="12" cy="8" r="4"/><path d="M3 21 C3 17 7 14 12 14 C17 14 21 17 21 21"/></svg>
                    <span>Manage Users</span>
                </a>
                <a href="/Notification/Index?role=admin" class="quick-action-btn" style="text-decoration:none;">
                    <svg viewBox="0 0 24 24" style="width:24px;height:24px;stroke:currentColor;"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    <span>SMS Notifications</span>
                </a>
                <a href="/Oversight/Index?role=admin" class="quick-action-btn" style="text-decoration:none;">
                    <svg viewBox="0 0 24 24" style="width:24px;height:24px;stroke:currentColor;"><circle cx="12" cy="12" r="10"/><path d="M12 6 V12 L16 14"/></svg>
                    <span>ARTA Compliance</span>
                </a>
            </div>
        </div>
    </div>

    <!-- Recent System Activity -->
    <div class="card" style="margin-top:20px;">
        <div class="card__header">
            <span class="card__title">Recent System Activity</span>
        </div>
        <div class="card__body">
            <ul style="list-style:none; padding:0;">
                @foreach (var act in Model.RecentActivity)
                {
                    <li style="padding: 10px 0; border-bottom: 1px solid #eee;">
                        <strong>@act.TrackingNumber</strong> — @act.Action by @act.PerformedBy
                        <span style="color:#888; font-size:12px; float:right;">@act.TimeAgo</span>
                    </li>
                }
                @if (!Model.RecentActivity.Any())
                {
                    <li style="color:#888;">No recent activity.</li>
                }
            </ul>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .quick-action-btn {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
            padding: 20px;
            border: 2px dashed var(--border-gray);
            border-radius: 8px;
            color: var(--text-body);
            transition: all 0.2s;
        }
        .quick-action-btn:hover {
            border-color: var(--blue);
            color: var(--blue);
            background: var(--blue-light);
        }
    </style>
}
