@{
    ViewData["Title"] = "SMS Notifications - Admin";
    Layout = "~/Views/Shared/_LayoutApp.cshtml";
}

<div class="page-body">
    <div class="page-header">
        <div>
            <h1 class="page-header__title">SMS Notifications</h1>
            <p class="page-header__subtitle">Executive Admin - Full notification management access</p>
        </div>
        <button class="btn btn--primary btn--md" onclick="openSendSMSModal()">+ Send Custom SMS</button>
    </div>

    <!-- Notification Stats -->
    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-card__number">127</div>
            <div class="stat-card__label">Total Sent</div>
            <div class="stat-card__sub">This month</div>
        </div>
        <div class="stat-card">
            <div class="stat-card__number" style="color:var(--warning)">12</div>
            <div class="stat-card__label">Queued</div>
            <div class="stat-card__sub">Pending delivery</div>
        </div>
        <div class="stat-card">
            <div class="stat-card__number" style="color:var(--danger)">3</div>
            <div class="stat-card__label">Failed</div>
            <div class="stat-card__sub">Delivery errors</div>
        </div>
        <div class="stat-card">
            <div class="stat-card__number" style="color:var(--success)">96%</div>
            <div class="stat-card__label">Success Rate</div>
            <div class="stat-card__sub">Overall delivery</div>
        </div>
    </div>

    <!-- Notification List -->
    <div class="card" style="margin-top:20px;">
        <div class="card__header">
            <span class="card__title">Recent SMS Notifications</span>
        </div>
        <div class="card__body" style="padding:0; overflow-x:auto;">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Date/Time</th>
                        <th>Recipient</th>
                        <th>Mobile Number</th>
                        <th>Tracking #</th>
                        <th>Trigger Event</th>
                        <th>Message</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Jun 29, 2026 1:30 PM</td>
                        <td>Juan Dela Cruz</td>
                        <td>+63 917 123 4567</td>
                        <td><a href="#">TRK-2026-0145</a></td>
                        <td><span class="badge badge--in-progress badge--table">Document Approved</span></td>
                        <td style="max-width:300px;">Your document TRK-2026-0145 has been approved...</td>
                        <td><span class="badge badge--completed badge--table">Sent</span></td>
                        <td><a href="#" class="view-link">Details</a></td>
                    </tr>
                    <tr>
                        <td>Jun 29, 2026 1:15 PM</td>
                        <td>Maria Santos</td>
                        <td>+63 917 765 4321</td>
                        <td><a href="#">TRK-2026-0144</a></td>
                        <td><span class="badge badge--warning badge--table">ARTA Warning</span></td>
                        <td style="max-width:300px;">Document nearing deadline. Please follow up...</td>
                        <td><span class="badge badge--completed badge--table">Sent</span></td>
                        <td><a href="#" class="view-link">Details</a></td>
                    </tr>
                    <tr>
                        <td>Jun 29, 2026 12:45 PM</td>
                        <td>Pedro Garcia</td>
                        <td>+63 917 555 1234</td>
                        <td><a href="#">TRK-2026-0143</a></td>
                        <td><span class="badge badge--returned badge--table">Document Returned</span></td>
                        <td style="max-width:300px;">Your document has been returned for revision...</td>
                        <td><span class="badge badge--completed badge--table">Sent</span></td>
                        <td><a href="#" class="view-link">Details</a></td>
                    </tr>
                    <tr>
                        <td>Jun 29, 2026 11:30 AM</td>
                        <td>Ana Reyes</td>
                        <td>+63 917 888 9999</td>
                        <td><a href="#">TRK-2026-0142</a></td>
                        <td><span class="badge badge--pending badge--table">Ready for Pickup</span></td>
                        <td style="max-width:300px;">Your document is ready for release. Visit...</td>
                        <td><span class="badge badge--pending badge--table">Queued</span></td>
                        <td><a href="#" class="view-link">Details</a></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- SMS Gateway Configuration (Admin Only) -->
    <div class="card" style="margin-top:20px; max-width:600px;">
        <div class="card__header">
            <span class="card__title">SMS Gateway Configuration</span>
        </div>
        <div class="card__body">
            <div class="form-group">
                <label class="form-label">Gateway Provider</label>
                <select class="form-select">
                    <option>Simulated Gateway</option>
                    <option>Semaphore</option>
                    <option>Twilio</option>
                    <option>Movider</option>
                </select>
            </div>
            <div class="form-group">
                <label class="form-label">API Key</label>
                <input type="password" class="form-input" value="*************************" />
            </div>
            <div class="form-group">
                <label class="form-label">Sender Name</label>
                <input type="text" class="form-input" value="TrackNGo" />
            </div>
            <button class="btn btn--primary btn--md">Save Configuration</button>
        </div>
    </div>
</div>

<!-- Send SMS Modal -->
<div class="modal-overlay" id="sendSMSModal">
    <div class="qr-modal" style="width: 500px;">
        <div class="qr-modal__header" style="background:#0F2A6B;">
            <span class="qr-modal__header-title">Send Custom SMS</span>
            <span class="qr-modal__close" onclick="closeSendSMSModal()">&times;</span>
        </div>
        <div class="qr-modal__body" style="text-align:left;">
            <div class="form-group">
                <label class="form-label">Mobile Number</label>
                <input type="tel" class="form-input" placeholder="+63 917 123 4567" />
            </div>
            <div class="form-group">
                <label class="form-label">Message</label>
                <textarea class="form-input" rows="4" placeholder="Enter your message..."></textarea>
                <p style="font-size:11px;color:#64748B;margin-top:4px;">160 characters maximum</p>
            </div>
            <button class="btn btn--primary btn--full btn--md">Send SMS Now</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openSendSMSModal() {
            document.getElementById('sendSMSModal').classList.add('active');
        }
        function closeSendSMSModal() {
            document.getElementById('sendSMSModal').classList.remove('active');
        }
    </script>
}
